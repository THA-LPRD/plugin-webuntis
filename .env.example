# Plugin Settings
LOG_LEVEL=INFO
REGISTRATION_KEY=your-registration-key-here

# Database (default: SQLite, swap to PostgreSQL via this var)
# DATABASE_URL=sqlite+aiosqlite:///data/plugin.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/plugin

# LPRD Registry
REGISTRY_URL=http://localhost:8000
PLUGIN_BASE_URL=http://localhost:8001
TIMEZONE=Europe/Berlin

# Sync Settings
SYNC_INTERVAL_MINUTES=60

# WebUntis (anonymous auth — no credentials needed)
UNTIS_SERVER=https://neilo.webuntis.com
UNTIS_SCHOOL=your-school-name
UNTIS_ROOMS=EDV1,EDV2,B201
